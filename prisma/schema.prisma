generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id        Int      @id @default(autoincrement())
  dni       String   @unique
  name      String
  lastName  String
  email     String   @unique
  phone     String
  birthdate DateTime
  password  String
  role      Role
  createdAt DateTime @default(now())

  teachers Teachers? @relation("TeachersUsers")
  students Students? @relation("StudentsUsers")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model Teachers {
  id             Int              @id @default(autoincrement())
  userID         Int              @unique
  user           Users            @relation("TeachersUsers", fields: [userID], references: [id])
  subjects       Subjects[]       @relation("SubjectsTeachers")
  evaluationPlan EvaluationPlan[] @relation("TeachersEvaluationPlan")
  schoolId       Int
  school         Schools          @relation("TeachersSchools", fields: [schoolId], references: [id])
}

model Students {
  id     Int   @id @default(autoincrement())
  userID Int   @unique
  user   Users @relation("StudentsUsers", fields: [userID], references: [id])

  // --- Paso 3: Salud ---
  birthCountry     String
  birthState       String
  bloodType        String
  allergies        String
  weight           String
  height           String
  shirtSize        String
  shoeSize         String
  pantSize         String
  medicalCondition String

  // --- Paso 5: Representante ---
  repDni             String
  representativeName String
  repLastName        String
  repPhone           String
  relationship       String
  repEmail           String

  //Ubication
  state            String
  municipality     String
  parish           String
  addressDetail    String
  housingCondition String

  // Académico
  previousSchool     String?
  previousSchoolCode String?
  canaimaSerial      String?
  previousYear       String?
  previousSection    String?

  //Escuela
  schoolId Int?
  school   Schools? @relation(fields: [schoolId], references: [id])
  year     String?
  section  String?

  qualifications Qualifications[] @relation("QualificationsStudents")
  parents        Parents?
}

model Subjects {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  teachers       Teachers[]       @relation("SubjectsTeachers")
  evaluationPlan EvaluationPlan[] @relation("EvaluationPlanSubjects")
}

model Qualifications {
  id        Int      @id @default(autoincrement())
  studentID Int
  student   Students @relation("QualificationsStudents", fields: [studentID], references: [id])

  evaluationPlanID Int
  evaluationPlan   EvaluationPlan @relation("QualificationsPlan", fields: [evaluationPlanID], references: [id])

  qualification Int
  createdAt     DateTime @default(now())
}

model EvaluationPlan {
  id        Int      @id @default(autoincrement())
  teacherID Int
  teacher   Teachers @relation("TeachersEvaluationPlan", fields: [teacherID], references: [id])

  subjectID Int
  subject   Subjects @relation("EvaluationPlanSubjects", fields: [subjectID], references: [id])

  lapse     Int // Cambiado a Int para facilitar cálculos
  period    String
  content   Json // Aquí guardas tu tabla de PV
  createdAt DateTime @default(now())

  qualifications Qualifications[] @relation("QualificationsPlan")
}

model Parents {
  id          Int    @id @default(autoincrement())
  studentId   Int    @unique
  motherName  String
  motherDni   String
  motherEmail String
  motherPhone String

  fatherName  String
  fatherDni   String
  fatherEmail String
  fatherPhone String

  student Students @relation(fields: [studentId], references: [id])
}

model Schools {
  id            Int    @id @default(autoincrement())
  rifSchool     String? @unique
  typeSchool    SchoolsType @default(PUBLIC)
  codeShool     String @unique
  nameSchool    String
  emailSchool   String @unique
  addressSchool String

  student  Students[]
  teachers Teachers[] @relation("TeachersSchools")
}

enum SchoolsType{
  PUBLIC
  PRIVATE
  SUBSIDIZED
}
